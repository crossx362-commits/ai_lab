# ─── Telegram API 헬퍼 ───────────────────────────────────────────────────────

def _api(method: str, payload: dict, _retry: int = 3) -> dict:
    url  = f"https://api.telegram.org/bot{TOKEN}/{method}"
    data = json.dumps(payload).encode("utf-8")
    req  = urllib.request.Request(url, data=data, headers={"Content-Type": "application/json"})
    for attempt in range(_retry):
        try:
            with urllib.request.urlopen(req, timeout=35) as r:
                return json.loads(r.read().decode())
        except urllib.error.HTTPError as e:
            if e.code == 409:
                wait = 20 * (attempt + 1)
                print(f"  [API 409 Conflict] {method} — {wait}초 대기 후 재시도 ({attempt+1}/{_retry})")
                time.sleep(wait)
            else:
                print(f"  [API Error] {method}: {e}")
                return {}
        except Exception as e:
            print(f"  [API Error] {method}: {e}")
            return {}
    print(f"  [API] {method} 재시도 초과")
    return {}


def _clear_webhook():
    """시작 시 Webhook 제거 — Long Polling과 충돌 방지"""
    url = f"https://api.telegram.org/bot{TOKEN}/deleteWebhook?drop_pending_updates=true"
    try:
        with urllib.request.urlopen(url, timeout=10) as r:
            res = json.loads(r.read().decode())
        if res.get("result"):
            print("  ✅ Webhook 제거 완료 (Long Polling 전환)")
        else:
            print(f"  ⚠️ Webhook 제거 응답: {res}")
    except Exception as e:
        print(f"  [Warning] Webhook 제거 실패: {e}")


_last_sent_message = {"text": "", "timestamp": 0}  # 중복 전송 방지

def send(text: str, chat_id: str = None):
    """텔레그램 메시지 전송 (중복 방지 기능 포함)"""
    global _last_sent_message

    # 디버깅: 호출 스택 추적 (필요 시 주석 해제)
    # import traceback
    # stack = traceback.extract_stack()
    # caller_info = f"{stack[-2].filename.split('/')[-1]}:{stack[-2].lineno} in {stack[-2].name}"
    # print(f"  [send() 호출] {caller_info} → {text[:50]}")

    # 중복 전송 방지: 동일 메시지가 3초 이내 재전송되면 무시
    now = time.time()
    if (_last_sent_message["text"] == text and
        now - _last_sent_message["timestamp"] < 3):
        print(f"  [중복 전송 방지] 동일 메시지 무시")
        return

    _last_sent_message["text"] = text
    _last_sent_message["timestamp"] = now

    _api("sendMessage", {
        "chat_id":    chat_id or CHAT_ID,
        "text":       text,
        "parse_mode": "HTML",
    })



