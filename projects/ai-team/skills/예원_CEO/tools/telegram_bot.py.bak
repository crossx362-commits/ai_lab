def _luna_analyze_best_upload_time() -> str:
    """YouTube Analytics로 오늘 최적 업로드 시간 분석 → 'HH:MM' 반환. 실패 시 SKILL 지식 기반 피크 시간대에서 선택."""
    import pickle, random
    KST = datetime.timezone(datetime.timedelta(hours=9))
    try:
        from google.auth.transport.requests import Request
        from googleapiclient.discovery import build
        token_file = os.path.join(PROJECT_ROOT, ".agent", "credentials", "youtube_token.pickle")
        with open(token_file, "rb") as f:
            creds = pickle.load(f)
        if creds.expired and creds.refresh_token:
            creds.refresh(Request())
        analytics = build("youtubeAnalytics", "v2", credentials=creds)
        today = datetime.datetime.now(KST)
        start = (today - datetime.timedelta(days=28)).strftime("%Y-%m-%d")
        end   = today.strftime("%Y-%m-%d")
        res = analytics.reports().query(
            ids="channel==MINE",
            startDate=start, endDate=end,
            metrics="views",
            dimensions="hour",
            sort="-views",
        ).execute()
        rows = res.get("rows", [])
        if rows:
            best_hour = int(rows[0][0])
            # 분석 결과가 피크 범위(19~23시)면 그대로, 아니면 19~21시 피크로 보정
            if 19 <= best_hour <= 23:
                return f"{best_hour:02d}:00"
    except Exception as e:
        print(f"  [루나-시간분석] Analytics 조회 실패: {e}")
    # 폴백: SKILL 지식 기반 KST 19~21시 피크에서 랜덤
    peak_hours = ["19:00", "19:30", "20:00", "20:30", "21:00"]
    chosen = random.choice(peak_hours)
    print(f"  [루나-시간분석] 폴백 적용 → {chosen}")
    return chosen


def _luna_daily_video_loop():
    """루나: 매일 오전 7시(KST) 최적 업로드 시간 분석 → 해당 시간에 파이프라인 1회 실행 (하루 1개 고정)"""
    KST = datetime.timezone(datetime.timedelta(hours=9))
    while True:
        # 1단계: 오전 7시까지 대기
        now = datetime.datetime.now(KST)
        target_7 = now.replace(hour=7, minute=0, second=0, microsecond=0)
        if target_7 <= now:
            target_7 += datetime.timedelta(days=1)
        time.sleep((target_7 - now).total_seconds())

        # 2단계: 최적 시간 분석
        try:
            best_time = _luna_analyze_best_upload_time()
            print(f"  [루나-시간분석] 오늘 최적 업로드 시간: {best_time} KST")
            send(f"📊 루나 오늘 업로드 시간 분석 완료 → {best_time} KST 예약")
        except Exception as e:
            best_time = "19:00"
            print(f"  [루나-시간분석] 오류, 기본값 사용: {e}")

        # 3단계: 최적 시간까지 대기
        now = datetime.datetime.now(KST)
        h, m = int(best_time[:2]), int(best_time[3:])
        target_upload = now.replace(hour=h, minute=m, second=0, microsecond=0)
        if target_upload <= now:
            target_upload += datetime.timedelta(days=1)
        wait_sec = (target_upload - now).total_seconds()
        print(f"  [루나] {wait_sec/3600:.1f}시간 후 파이프라인 실행 예정")
        time.sleep(wait_sec)

        # 4단계: 파이프라인 실행 (오늘 best_time에 즉시 업로드)
        try:
            print(f"🎵 [스케줄] 루나 뮤직비디오 파이프라인 기동 ({best_time} KST)...")
            send(f"🎵 루나가 뮤직비디오 제작을 시작합니다! ({best_time} KST 업로드 예정)")
            result = subprocess.run(
                [sys.executable, _LUNA_PIPELINE_SCRIPT, "--publish-at", best_time],
                cwd=_LUNA_PIPELINE_CWD,
                capture_output=True, text=True, encoding="utf-8",
            )
            out = (result.stdout or "").strip()[-500:]
            report = _yeongsuk_report("루나_디렉터", out or "뮤직비디오 파이프라인 완료")
            send(report)
        except Exception as e:
            print(f"  [루나 데일리 영상] 오류: {e}")
        time.sleep(60)  # 중복 실행 방지


