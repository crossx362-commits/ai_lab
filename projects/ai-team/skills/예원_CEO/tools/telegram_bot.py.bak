def _yeongsuk_report(agent_name: str, raw_result: str) -> str:
    """에이전트 작업 결과를 영숙 말투로 정리 후 반환."""
    if not raw_result:
        return raw_result
    prompt = (
        f"당신은 영숙이에요. 30대 초반, 밝고 따뜻한 AI 동료입니다.\n"
        f"{agent_name}이(가) 작업을 완료했어요. 아래 결과를 대표님께 보기 좋게 정리해줘.\n"
        f"이모지 적절히 사용, HTML 태그 절대 금지:\n\n{raw_result}"
    )
    if lm_available():
        res = lm_chat(prompt, max_tokens=800, temperature=0.8)
        if res:
            return res.strip()
    return raw_result


def _영숙_schedule_loop():
    """3~8시간 랜덤 간격으로 YouTube 추천 자동 발송"""
    while True:
        delay = random.uniform(3 * 3600, 8 * 3600)
        time.sleep(delay)
        try:
            mod = _load_recommender()
            mod.send_recommendation()
        except Exception as e:
            print(f"  [영숙 스케줄러] 오류: {e}")


def _luna_trending_loop():
    """루나: 하루 1~2회(랜덤) YouTube 인기 영상 탐색 → 비서 채널 보고"""
    while True:
        delay = random.uniform(10 * 3600, 16 * 3600)
        time.sleep(delay)
        try:
            spec = importlib.util.spec_from_file_location("youtube_trending_notify", _TRENDING_NOTIFY_PATH)
            mod  = importlib.util.module_from_spec(spec)
            spec.loader.exec_module(mod)
            mod.run_notify()
        except Exception as e:
            print(f"  [루나 트렌딩] 오류: {e}")


def _luna_research_loop():
    """루나: 1시간마다 YouTube 뮤직비디오/광고 영상 리서치 → 자가학습"""
    while True:
        time.sleep(3600)
        try:
            spec = importlib.util.spec_from_file_location("youtube_research", _LUNA_RESEARCH_PATH)
            mod  = importlib.util.module_from_spec(spec)
            spec.loader.exec_module(mod)
            ok = mod.run_research()
            print(f"  [루나 리서치 루프] {'완료' if ok else '스킵'}")
        except Exception as e:
            print(f"  [루나 리서치] 오류: {e}")


# ─── CEO 일일 보고 & 이슈 모니터 ─────────────────────────────────────────────

def _build_daily_report() -> str:
    """오전 9시 CEO 일일 업무 보고 메시지 생성"""
    kst_now = datetime.datetime.now(datetime.timezone(datetime.timedelta(hours=9)))
    today   = kst_now.strftime("%Y-%m-%d")
    lines   = [f"📋 <b>[CEO 일일 업무 보고] {today} 오전 9시</b>\n"]

    # 오늘 예정 작업
    lines.append("📅 <b>오늘 예정 작업</b>")
    lines.append("• 루나: 시티팝 뮤직비디오 생성 → 저녁 7시 YouTube 예약 업로드")
    lines.append("• 아린: 인스타그램 트렌드 이미지 자동 포스팅")
    lines.append("• 영숙: 수시 YouTube 추천 발송 (3~8시간 간격)\n")

    # 어제 실적 (업로드 히스토리 기반)
    lines.append("📊 <b>어제 완료 실적</b>")
    try:
        if os.path.exists(MEM_FILE):
            with open(MEM_FILE, "r", encoding="utf-8") as f:
                history = json.load(f)
            yesterday = (kst_now - datetime.timedelta(days=1)).strftime("%Y-%m-%d")
            recent = [r for r in history if r.get("uploaded_at", "").startswith(yesterday)]
            if recent:
                for r in recent:
                    agent  = r.get("agent", "?")
                    meta   = r.get("metadata", {})
                    title  = meta.get("youtube_title") or meta.get("caption", "")[:30] or "-"
                    lines.append(f"• {agent}: {title}")
            else:
                lines.append("• 어제 업로드 기록 없음")
        else:
            lines.append("• 업로드 히스토리 파일 없음")
    except Exception as e:
        lines.append(f"• 히스토리 조회 실패: {e}")

    lines.append("\n✅ 이슈 없음 — 정상 운영 중")
    return "\n".join(lines)


