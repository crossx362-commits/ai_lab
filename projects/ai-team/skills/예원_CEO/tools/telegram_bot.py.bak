/research  — 현빈 일반 비즈니스 리서치
/deepsearch [주제] — 현빈 6시간 딥서치 (백그라운드)
/vercel    — 케빈 Vercel 서버 클린업
/tax [금액] — 로율 법률·세무 시뮬레이션
/report    — 최근 업로드 히스토리
/inspect [ID] — 가희 콘텐츠 품질 검수 (전체 or 영상ID 지정)
/skillaudit   — 예원 에이전트 스킬 감사
/help      — 이 도움말"""


def cmd_status() -> str:
    result = subprocess.run(
        [sys.executable, UPLOAD_MANAGER, "--check"],
        capture_output=True, text=True, encoding="utf-8",
        cwd=PROJECT_ROOT,
    )
    out = result.stdout.strip() or "현황을 가져올 수 없습니다."
    return f"📋 <b>업로드 현황</b>\n\n{out}"


def cmd_upload() -> str:
    # 중복 메시지 방지: 중간 알림 제거
    # send("⏳ 누락 파이프라인 확인 중...")
    result = subprocess.run(
        [sys.executable, UPLOAD_MANAGER, "--run"],
        capture_output=True, text=True, encoding="utf-8",
        cwd=PROJECT_ROOT,
    )
    out = result.stdout.strip() or "실행 결과 없음."
    return f"🚀 <b>업로드 실행 완료</b>\n\n{out}"


def _run_pipeline(agent: str) -> str:
    cfg = PIPELINES.get(agent)
    if not cfg:
        return f"❌ 알 수 없는 에이전트: {agent}"
    # 중복 메시지 방지: 시작 알림 제거, 최종 결과만 반환
    # send(f"⏳ {agent} 파이프라인 시작 중...")

    # 파이프라인 실행 시 텔레그램 전송 비활성화 (중복 방지)
    env = os.environ.copy()
    env["SUPPRESS_TELEGRAM"] = "1"

    result = subprocess.run(
        [sys.executable, cfg["script"]],
        capture_output=True, text=True, encoding="utf-8",
        cwd=cfg["cwd"],
        env=env,
    )
    if result.returncode == 0:
        return f"✅ {agent} 파이프라인 완료!"
    else:
        err = (result.stderr or result.stdout or "")[-300:]
        return f"❌ {agent} 파이프라인 실패\n<pre>{err}</pre>"


def cmd_evaluate() -> str:
    # 중복 메시지 방지: 중간 알림 제거
    # send("⏳ 성과 평가 중...")
    result = subprocess.run(
        [sys.executable, EVALUATE_SCRIPT],
        capture_output=True, text=True, encoding="utf-8",
        cwd=PROJECT_ROOT,
    )
    out = result.stdout.strip() or "평가 결과 없음."
    return f"📊 <b>RL 성과 평가</b>\n\n{out}"


def cmd_report() -> str:
    if not os.path.exists(MEM_FILE):
        return "📭 업로드 히스토리가 없습니다."
    with open(MEM_FILE, "r", encoding="utf-8") as f:
        history = json.load(f)

    cutoff = (datetime.datetime.now() - datetime.timedelta(days=7)).isoformat()
    recent = [r for r in history if r.get("uploaded_at", "") >= cutoff]

    if not recent:
        return "📭 최근 7일 업로드 기록이 없습니다."

    lines = [f"📋 <b>최근 업로드 ({len(recent)}건)</b>\n"]
    for r in sorted(recent, key=lambda x: x.get("uploaded_at", ""), reverse=True)[:10]:
        agent    = r.get("agent", "?")
        status   = r.get("status", "?")
        uploaded = r.get("uploaded_at", "")[:16]
        meta     = r.get("metadata", {})
        title    = meta.get("youtube_title") or meta.get("caption", "")[:30] or meta.get("veo_prompt", "")[:30] or "-"
        icon     = "✅" if status in ("published", "evaluated") else "⏳"
        lines.append(f"{icon} <b>{agent}</b> [{uploaded}]\n   {title}")

    return "\n".join(lines)

