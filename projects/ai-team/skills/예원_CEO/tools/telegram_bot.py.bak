def _ceo_trend_alert_loop():
    """30분마다 Google Trends + 뉴스 RSS 체크 → 급상승 트렌드 즉시 CEO 알림"""
    import urllib.parse
    import xml.etree.ElementTree as ET

    TREND_RSS   = "https://trends.google.com/trending/rss?geo=KR"
    NEWS_RSS    = "https://news.google.com/rss?hl=ko&gl=KR&ceid=KR:ko"
    seen_trends: set = set()
    cycle = 0

    def _fetch_rss_titles(url: str) -> list[str]:
        try:
            req = urllib.request.Request(url, headers={"User-Agent": "Mozilla/5.0"})
            with urllib.request.urlopen(req, timeout=10) as r:
                root = ET.fromstring(r.read())
            return [
                item.findtext("title", "").strip()
                for item in root.findall(".//item")
                if item.findtext("title", "").strip()
            ]
        except Exception:
            return []

    def _assess(items: list[str]) -> str | None:
        """Ollama(1순위) → Gemini(2순위)로 급상승 트렌드 중요도 판별."""
        if not items:
            return None
        sample = "\n".join(f"- {t}" for t in items[:15])
        prompt = (
            f"다음은 현재 한국에서 급상승 중인 트렌드/뉴스입니다:\n{sample}\n\n"
            "이 중 AI 크리에이터 팀(음악, 인스타, YouTube) 비즈니스에 "
            "즉시 주목해야 할 이슈나 기회가 있으면 1~2줄로 요약해줘. "
            "없으면 정확히 'NONE'만 반환."
        )
        try:
            from _shared import gemini_client as _gc_trend
            text = _gc_trend.text(prompt, max_tokens=150, temperature=0.5, task="")
            if text and not text.strip().upper().startswith("NONE"):
                return text.strip()
        except Exception:
            pass
        return None

    while True:
        time.sleep(1800)  # 30분
        try:
            trends = _fetch_rss_titles(TREND_RSS)
            news   = _fetch_rss_titles(NEWS_RSS)[:10]
            new_items = [t for t in trends + news if t not in seen_trends]
            if not new_items:
                cycle += 1
                continue
            seen_trends.update(new_items)
            # 매 3번째 사이클에만 Gemini 평가 (API 절약)
            cycle += 1
            if cycle % 3 != 1:
                continue
            summary = _assess(new_items)
            if summary:
                kst_now = datetime.datetime.now(datetime.timezone(datetime.timedelta(hours=9)))
                ts = kst_now.strftime("%m/%d %H:%M")
                alert = (
                    f"🚨 <b>[즉시 보고] 급상승 트렌드 감지</b> ({ts})\n\n"
                    f"{summary}\n\n"
                    f"<i>관련 키워드: {', '.join(new_items[:5])}</i>"
                )
                send(alert)
                print(f"  [트렌드 알림] 발송: {summary[:50]}")
        except Exception as e:
            print(f"  [트렌드 알림] 오류: {e}")


def _get_system_specs() -> dict:
    """현재 컴퓨터 하드웨어 사양 수집 (macOS 기준)."""
    import subprocess as _sp
    specs = {}
    try:
        mem_bytes = int(_sp.check_output(["sysctl", "-n", "hw.memsize"], text=True).strip())
        specs["ram_gb"] = mem_bytes // (1024 ** 3)
    except Exception:
        specs["ram_gb"] = 0
    try:
        specs["cpu"] = _sp.check_output(["sysctl", "-n", "machdep.cpu.brand_string"], text=True).strip()
    except Exception:
        specs["cpu"] = "Unknown"
    try:
        hw = _sp.check_output(["system_profiler", "SPHardwareDataType"], text=True)
        for line in hw.splitlines():
            if "Model Name" in line:
                specs["model"] = line.split(":", 1)[-1].strip()
            if "Chip" in line and "chip" not in line.lower().replace("Chip", ""):
                specs["chip"] = line.split(":", 1)[-1].strip()
    except Exception:
        pass
    return specs


def _research_local_ai(specs: dict) -> str:
    """Gemini(1순위) 또는 Ollama로 사양에 맞는 로컬 AI 모델 추천 리서치."""
    ram   = specs.get("ram_gb", 0)
    cpu   = specs.get("cpu", "")
    model = specs.get("model", "")
    chip  = specs.get("chip", cpu)

    prompt = (
        f"내 컴퓨터 사양:\n"
        f"- 기기: {model}\n"
        f"- 칩: {chip}\n"
        f"- 통합 메모리: {ram}GB\n\n"
        f"이 사양으로 Ollama에서 실행 가능한 최신 로컬 AI 모델을 추천해줘.\n"
        f"조건:\n"
        f"- 2024~2025년 출시 모델 위주\n"
        f"- Hugging Face / Ollama 커뮤니티에서 인기 있는 모델\n"
        f"- 코딩용, 일반대화용, 창작/블로그용으로 각 1~2개씩 추천\n"
        f"- 각 모델마다: 이름, 파라미터 크기, 양자화 권장(Q4/Q5/Q8), 예상 속도(토큰/초), 추천 이유\n"
        f"- 실행 불가능한 모델은 제외\n"
        f"- 한국어로 작성\n"
        f"- 전체 500자 이내로 요약"
    )

    # 1순위: Gemini (최신 정보 접근 가능)
    api_key = os.getenv("GEMINI_API_KEY", "")
    if api_key:
        url = (
            "https://generativelanguage.googleapis.com/v1beta/models/"
            f"gemini-2.5-flash:generateContent?key={api_key}"
        )
        try:
            payload = json.dumps({
                "contents": [{"parts": [{"text": prompt}]}],
                "generationConfig": {"maxOutputTokens": 800},
            }).encode()
            req = urllib.request.Request(url, data=payload, headers={"Content-Type": "application/json"})
            with urllib.request.urlopen(req, timeout=20) as r:
                res = json.loads(r.read())
            text = res["candidates"][0]["content"]["parts"][0]["text"].strip()
            if text:
                return text
        except Exception as e:
            print(f"  [CEO AI리서치] Gemini 실패 ({e}) → Ollama 폴백")

    # 2순위: Ollama 로컬
    if lm_available():
        result = lm_chat(prompt, max_tokens=600, temperature=0.5, task="")
        if result:
            return result

    return None


def _ceo_ai_research_loop():
    """하루 2회(오전 10시, 오후 9시 KST) 로컬 AI 모델 리서치 → CEO 텔레그램 보고."""
    KST = datetime.timezone(datetime.timedelta(hours=9))
    REPORT_HOURS = (10, 21)  # 오전 10시, 오후 9시

    def _next_target() -> datetime.datetime:
        now = datetime.datetime.now(KST)
        for h in sorted(REPORT_HOURS):
            t = now.replace(hour=h, minute=0, second=0, microsecond=0)
            if t > now:
                return t
        # 오늘 모두 지났으면 내일 첫 번째 시간
        tomorrow = now + datetime.timedelta(days=1)
        return tomorrow.replace(hour=REPORT_HOURS[0], minute=0, second=0, microsecond=0)

    while True:
        target = _next_target()
        wait_sec = (target - datetime.datetime.now(KST)).total_seconds()
        time.sleep(max(wait_sec, 1))

        try:
            specs = _get_system_specs()
            kst_now = datetime.datetime.now(KST).strftime("%Y-%m-%d %H:%M KST")
            print(f"  [CEO AI리서치] 시작 — {kst_now} | {specs}")

            result = _research_local_ai(specs)
            if result:
                ram  = specs.get("ram_gb", "?")
                chip = specs.get("chip", specs.get("cpu", "?"))
                msg  = (
                    f"🤖 <b>[CEO 로컬 AI 리서치] {kst_now}</b>\n\n"
                    f"💻 <b>사양:</b> {chip} / {ram}GB\n\n"
                    f"{result}"
                )
            else:
                msg = f"⚠️ [CEO AI리서치] {kst_now} — AI 리서치 응답 없음 (Gemini·Ollama 모두 실패)"

            send(msg)
            print(f"  [CEO AI리서치] 보고 완료")
        except Exception as e:
            print(f"  [CEO AI리서치] 오류: {e}")

        time.sleep(60)  # 중복 실행 방지


_auto_heal_cooldown: dict = {}  # agent → last heal timestamp (중복 실행 방지)


def _auto_heal(agent: str, error_line: str):
    """이슈 감지 시 에이전트들이 자율 협업으로 문제 해결.

    흐름:
      1. CEO(예원) Ollama로 원인 분석 + 담당 에이전트 선정
      2. 관련 에이전트 파이프라인 자동 재실행
      3. 가희 사후 검수
      4. 결과 텔레그램 보고
    """
    now = time.time()
    if now - _auto_heal_cooldown.get(agent, 0) < 600:  # 10분 쿨다운
        return
    _auto_heal_cooldown[agent] = now

    send(f"🤖 <b>[예원]</b> {agent} 오류 감지 — 에이전트 자율 복구 시작합니다.")
    print(f"  [자율복구] {agent} 복구 시작: {error_line[:60]}")

    # ── Step 1: CEO(Ollama)가 원인 분석 + 복구 전략 결정 ──────────────────────
    fix_strategy = "rerun"
    if lm_available():
        prompt = (
            f"에이전트 [{agent}]에서 다음 오류가 발생했어:\n\n"
            f"오류: {error_line[:300]}\n\n"
            "이 오류의 원인과 자동 복구 전략을 JSON으로 반환해.\n"
            '{"cause": "원인 1줄", "strategy": "rerun|token_refresh|skip", '
            '"agents_needed": ["에이전트명"]}'
        )
        raw = lm_chat(prompt, task="", max_tokens=200, json_mode=True)
        if raw:
            try:
                plan = json.loads(raw)
                fix_strategy = plan.get("strategy", "rerun")
                agents_needed = plan.get("agents_needed", [agent])
                cause = plan.get("cause", "원인 미상")
                send(f"🔍 <b>[예원 분석]</b>\n원인: {cause}\n전략: {fix_strategy}\n담당: {', '.join(agents_needed)}")
                print(f"  [자율복구] 전략={fix_strategy}, 담당={agents_needed}")
            except Exception:
                pass

    # ── Step 2: 전략별 복구 실행 ──────────────────────────────────────────────
    result_msg = ""

    if fix_strategy == "token_refresh" or "아린" in agent:
        # 아린: 토큰 갱신 후 파이프라인 재실행
        send("🔧 <b>[아린]</b> Instagram 토큰 갱신 중...")
        try:
            spec = importlib.util.spec_from_file_location(
                "uploader", os.path.join(PROJECT_ROOT, ".agent", "skills", "아린_관리자", "tools", "uploader.py"))
            mod = importlib.util.module_from_spec(spec); spec.loader.exec_module(mod)
            mod.ensure_token_fresh()
            result_msg = "아린: 토큰 갱신 완료 ✅"
        except Exception as e:
            result_msg = f"아린: 토큰 갱신 실패 ❌ ({e})"

    if fix_strategy in ("rerun", "token_refresh") and "루나" in agent:
        # 루나: 체크포인트 클리어 후 파이프라인 재실행
        send("🔧 <b>[루나]</b> 파이프라인 재시작 중...")
        cp_file = os.path.join(PROJECT_ROOT, ".agent", "skills", "루나_디렉터", "tools", "output", "music_video_checkpoint.json")
        if os.path.exists(cp_file):
            try: os.remove(cp_file)
            except Exception: pass
        try:
            r = subprocess.run(
                [sys.executable, _LUNA_PIPELINE_SCRIPT],
                cwd=_LUNA_PIPELINE_CWD,
                capture_output=True, text=True, encoding="utf-8", timeout=600,
            )
            out = (r.stdout or "").strip()[-300:]
            result_msg = f"루나: 재실행 {'완료 ✅' if r.returncode == 0 else '실패 ❌'}\n{out}"
        except Exception as e:
            result_msg = f"루나: 재실행 실패 ❌ ({e})"

    if fix_strategy in ("rerun", "token_refresh") and "아린" in agent:
        # 아린: 파이프라인 재실행
        send("🔧 <b>[아린]</b> 인스타 파이프라인 재실행 중...")
        try:
            r = subprocess.run(
                [sys.executable, _ARIN_PIPELINE_SCRIPT],
                cwd=_ARIN_PIPELINE_CWD,
                capture_output=True, text=True, encoding="utf-8", timeout=300,
            )
            out = (r.stdout or "").strip()[-300:]
            result_msg += f"\n아린: 재실행 {'완료 ✅' if r.returncode == 0 else '실패 ❌'}\n{out}"
        except Exception as e:
            result_msg += f"\n아린: 재실행 실패 ❌ ({e})"

    # ── Step 3: 가희 사후 검수 ─────────────────────────────────────────────────
    try:
        spec = importlib.util.spec_from_file_location(
            "content_inspector", _GAHEE_INSPECTOR_PATH)
        ci = importlib.util.module_from_spec(spec); spec.loader.exec_module(ci)
        insta_results = ci._check_instagram_posts()
        issues = [r for r in insta_results if r.get("issues")]
        if issues:
            result_msg += f"\n⚠️ 가희 검수: 위반 {len(issues)}건 발견"
        else:
            result_msg += "\n✅ 가희 검수: 이상 없음"
    except Exception:
        pass

    # ── Step 4: 결과 보고 ──────────────────────────────────────────────────────
    final = result_msg.strip() or "복구 시도 완료 (결과 미확인)"
    send(f"📋 <b>[예원]</b> 자율 복구 결과\n\n{final}")
    print(f"  [자율복구] 완료: {final[:80]}")


def _ceo_issue_monitor_loop():
    """에이전트 로그에서 오류 감지 → CEO 알림 + 자율 복구 시작"""
    LOG_PATHS = {
        "루나_디렉터":  os.path.join(PROJECT_ROOT, ".agent", "skills", "루나_디렉터", "tools", "output", "pipeline.log"),
        "아린_관리자":  os.path.join(PROJECT_ROOT, ".agent", "skills", "아린_관리자", "tools", "pipeline.log"),
        "봇":   os.path.join(_here, "telegram_bot.log"),
    }
    last_sizes = {k: 0 for k in LOG_PATHS}
    ERROR_KEYWORDS = ["❌", "Error", "ERROR", "Exception", "Traceback", "실패"]
    IGNORE_PATTERNS = ["getUpdates", "read operation timed out", "토큰 조회"]

    while True:
        time.sleep(300)  # 5분마다 체크
        for agent, log_path in LOG_PATHS.items():
            if not os.path.exists(log_path):
                continue
            try:
                size = os.path.getsize(log_path)
                if size <= last_sizes[agent]:
                    last_sizes[agent] = size
                    continue
                with open(log_path, "r", encoding="utf-8", errors="ignore") as f:
                    f.seek(last_sizes[agent])
                    new_lines = f.read()
                last_sizes[agent] = size

                for line in new_lines.splitlines():
                    if any(ig in line for ig in IGNORE_PATTERNS):
                        continue
                    if any(kw in line for kw in ERROR_KEYWORDS):
                        alert = (
                            f"⚠️ <b>[CEO 이슈 알림] {agent} 에이전트</b>\n"
                            f"<code>{line[:200]}</code>"
                        )
                        send(alert)
                        print(f"  [이슈모니터] {agent}: {line[:60]}")
                        # 자율 복구 스레드 시작 (봇 자체 오류는 제외)
                        if agent != "봇":
                            threading.Thread(
                                target=_auto_heal, args=(agent, line),
                                daemon=True, name=f"자율복구-{agent}"
                            ).start()
                        break
            except Exception as e:
                print(f"  [이슈모니터] {agent} 로그 읽기 실패: {e}")


# ─── 라우터 ──────────────────────────────────────────────────────────────────

KEYWORD_MAP = {
    # 상태 조회
    "현황": cmd_status, "상태": cmd_status, "status": cmd_status,
    # 업로드 실행
    "업로드": cmd_upload, "upload": cmd_upload,
    # 평가
    "평가": cmd_evaluate, "evaluate": cmd_evaluate,
    # 히스토리
    "리포트": cmd_report, "report": cmd_report, "히스토리": cmd_report,
}


def route(text: str) -> str:
    """
    메시지 흐름:
      사용자 → CEO(예원) 분석 및 배분 → 에이전트 실행 → 영숙 결과 정리 → 사용자
    """
    text = text.strip()
    low  = text.lower()

    # ── 슬래시 명령: CEO 없이 직접 실행 ─────────────────────────────────
    if low.startswith("/help"):      return HELP_TEXT
    if low.startswith("/status"):    return cmd_status()
    if low.startswith("/upload"):    return cmd_upload()
    if low.startswith("/luna"):
        return _yeongsuk_report("루나_디렉터", _run_pipeline("루나_디렉터"))
    if low.startswith("/instagram"):
        return _yeongsuk_report("아린_관리자", _run_pipeline("아린_관리자"))
    if low.startswith("/evaluate"):  return cmd_evaluate()
    if low.startswith("/report"):    return cmd_report()
    if low.startswith("/ceo"):       return _build_daily_report()
    if low.startswith("/trending"):
        try:
            spec = importlib.util.spec_from_file_location("youtube_trending_notify", _TRENDING_NOTIFY_PATH)
            mod  = importlib.util.module_from_spec(spec)
            spec.loader.exec_module(mod)
            mod.run_notify()
            return "📺 루나가 인기 영상 리포트를 비서 채널로 보고했어요!"
        except Exception as e:
            return f"❌ 트렌딩 조회 실패: {e}"
    if low.startswith("/영숙"):
        msg = text[3:].strip()
        return cmd_영숙_recommend() if not msg else call_영숙(msg)
    if low.startswith("/예원"):
        msg = text[3:].strip()
        return "예원이한테 하실 말을 입력해주세요! 😊" if not msg else call_예원(msg)
    if low.startswith("/inspect"):
        vid_id = text[8:].strip() if len(text) > 8 else ""
        send("🔎 가희가 검수를 시작합니다...")
        try:
            args = [sys.executable, _GAHEE_INSPECTOR_PATH]
            if vid_id:
                args += ["--id", vid_id]
            result = subprocess.run(
                args, capture_output=True, text=True, encoding="utf-8",
                cwd=os.path.dirname(_GAHEE_INSPECTOR_PATH),
            )
            out = (result.stdout or "").strip()[-800:]
            return _yeongsuk_report("가희_검수관", out or "검수 완료")
        except Exception as e:
            return f"❌ 가희 검수 실패: {e}"
    if low.startswith("/skillaudit"):
        send("📋 예원이 에이전트 스킬 감사 시작할게요! 잠시만요...")
        try:
            result = subprocess.run(
                [sys.executable, _CEO_SKILL_AUDITOR_PATH],
                capture_output=True, text=True, encoding="utf-8",
                cwd=os.path.dirname(_CEO_SKILL_AUDITOR_PATH),
            )
            return result.stdout.strip()[-800:] or "스킬 감사 완료"
        except Exception as e:
            return f"❌ 스킬 감사 실패: {e}"

    # ── 자연어: CEO(예원) 분석 → 에이전트 배분 → 영숙 보고 ──────────────
    # 1단계: CEO 분석 (Ollama 우선)
    dispatch = _yewon_dispatch(text)

    if dispatch:
        agent    = dispatch.get("agent", "예원")
        yw_reply = dispatch.get("reply", "")
        print(f"  [예원 배분] agent={agent} | {yw_reply[:40] if yw_reply else '(reply 없음)'}")

        # CEO 배분 알림은 로그에만 (중복 전송 방지)
        # if yw_reply:
        #     send(f"👑 예원: {yw_reply}")

        # 2단계: 에이전트 실행
        if agent == "아린_관리자":
            raw = _run_pipeline("아린_관리자")
            # 3단계: 영숙이 결과 정리 후 보고 (단일 메시지)
            return _yeongsuk_report("아린_관리자", raw)
        elif agent == "루나_디렉터":
            raw = _run_pipeline("루나_디렉터")
            # 3단계: 영숙이 결과 정리 후 보고 (단일 메시지)
            return _yeongsuk_report("루나_디렉터", raw)
        elif agent == "영숙_비서":
            # 영숙 대화는 그대로 반환 (이미 영숙 말투)
            return call_영숙(text)
        elif agent == "현빈" or agent == "현빈_전략가":
            res = _run_hyunbin()
            return f"👑 예원: {yw_reply}\n\n{res}" if yw_reply else res
        elif agent == "케빈":
            res = _run_kevin()
            return f"👑 예원: {yw_reply}\n\n{res}" if yw_reply else res
        elif agent == "로율":
            res = _run_loyul()
            return f"👑 예원: {yw_reply}\n\n{res}" if yw_reply else res
        elif agent == "코다리_개발자":
            return f"👑 예원: {yw_reply}" if yw_reply else f"👑 예원: {agent}한테 요청했어!"
        else:
            # 예원 직접 응답 — reply가 있으면 그대로 사용, 없으면 Gemini/Ollama로 대화 생성
            if yw_reply:
                return f"👑 예원: {yw_reply}"
            else:
                # dispatch에서 reply 없이 agent="예원"만 반환한 경우 → 대화 생성
                return call_예원(text)

    # Ollama 미가동 → Gemini CEO 분석 (캘린더·복잡한 명령 처리)
    print(f"  [Gemini CEO 분석 중] {text}")
    res = call_gemini(text, force_gemini=True)  # Ollama 재시도 방지
    mode = res.get("mode", "reply")

    if mode in ("reply", "ask"):
        return res.get("text", "")
    elif mode == "calendar_create":
        return handle_calendar_create(res.get("event", {}))
    elif mode == "calendar_list":
        return handle_calendar_list(int(res.get("days_ahead") or 7))
    elif mode == "calendar_delete":
        return handle_calendar_delete(res.get("query", ""), int(res.get("days_ahead") or 7), bool(res.get("delete_all", False)))
    elif mode == "calendar_update":
        return handle_calendar_update(res.get("query", ""), int(res.get("days_ahead") or 7), res.get("patch", {}))
    elif mode == "dispatch":
        dispatch_msg = res.get("dispatch_to_ceo", "")
        task_title = res.get("track_task", {}).get("title", "비서 작업 전달")
        return (
            f"📨 CEO 업무 전달 완료\n"
            f"요청하신 작업({task_title})이 CEO 에이전트에 전달되었습니다.\n\n"
            f"전달 지시서:\n\"{dispatch_msg}\""
        )

    return "❓ 명령을 해석하였으나 처리 모드가 정의되지 않았습니다."

# ─── 메인 루프 ───────────────────────────────────────────────────────────────

_PID_FILE = os.path.join(_here, "telegram_bot.pid")


def _check_single_instance():
    """중복 실행 방지 — PID 파일로 단일 인스턴스 보장."""
    if os.path.exists(_PID_FILE):
        try:
            old_pid = int(open(_PID_FILE).read().strip())
            import psutil
            if psutil.pid_exists(old_pid):
                print(f"⚠️ 이미 실행 중인 봇 감지 (PID={old_pid}) — 기존 프로세스 종료 후 재시작")
                psutil.Process(old_pid).terminate()
                time.sleep(2)
        except Exception:
            pass
    with open(_PID_FILE, "w") as f:
        f.write(str(os.getpid()))



def _ceo_feedback_loop():
    """CEO(예원): 매일 오후 8시(KST) 유튜브 피드백/평가 자동 실행"""
    import datetime
    import time
    KST_TZ = datetime.timezone(datetime.timedelta(hours=9))
    while True:
        now = datetime.datetime.now(KST_TZ)
        target = now.replace(hour=20, minute=0, second=0, microsecond=0)
        if now >= target:
            target += datetime.timedelta(days=1)
        wait_seconds = (target - now).total_seconds()
        time.sleep(wait_seconds)
        try:
            res = cmd_evaluate()
            send(f"👑 예원: 오늘의 유튜브 피드백(RL 성과 평가) 결과를 가져왔어! 📊\n\n{res}")
        except Exception as e:
            print(f"  [CEO 피드백 스케줄러] 오류: {e}")

def main():
    if not TOKEN or not CHAT_ID:
        print("❌ 토큰 또는 chat_id 없음 — .env 파일 확인 요망")
        sys.exit(1)

    _check_single_instance()
    once = "--once" in sys.argv

    # 백그라운드 스레드 시작
    if not once:
        threading.Thread(target=_luna_research_loop,     daemon=True, name="루나-리서치(1h)").start()
        threading.Thread(target=_arin_research_loop,    daemon=True, name="아린-리서치(1h)").start()
        threading.Thread(target=_hyunbin_research_loop, daemon=True, name="현빈-리서치(1h)").start()
        threading.Thread(target=_영숙_schedule_loop,     daemon=True, name="영숙-추천").start()
        threading.Thread(target=_luna_trending_loop,    daemon=True, name="루나-트렌딩").start()
        threading.Thread(target=_ceo_report_loop,        daemon=True, name="CEO-9시보고").start()
        threading.Thread(target=_ceo_trend_alert_loop,  daemon=True, name="트렌드-30m").start()
        threading.Thread(target=_ceo_issue_monitor_loop, daemon=True, name="이슈모니터").start()
        threading.Thread(target=_ceo_ai_research_loop,  daemon=True, name="CEO-AI리서치(2회/일)").start()
        threading.Thread(target=_kyungsu_forensics_loop, daemon=True, name="경수-수사(18시)").start()
        threading.Thread(target=_kodari_health_loop,    daemon=True, name="코다리-봇진단(2h)").start()
        threading.Thread(target=_luna_audit_loop,        daemon=True, name="루나-감사(4시)").start()
        threading.Thread(target=_posting_schedule_loop,  daemon=True, name="영숙-캘린더(8시)").start()
        threading.Thread(target=_ceo_skill_audit_loop,   daemon=True, name="CEO-스킬감사(월9시)").start()
        threading.Thread(target=_gahee_inspection_loop,  daemon=True, name="가희-검수(5시)").start()
        threading.Thread(target=_luna_daily_video_loop,  daemon=True, name="루나-영상(매일10시)").start()
        print("🧵 백그라운드 16개: 루나·아린·현빈 리서치(1h) / 영숙추천 / 루나트렌딩 / CEO9시보고 / 트렌드30m / 이슈모니터 / CEO-AI리서치 / 경수수사(18시) / 코다리헬스(2h) / 루나감사(4시) / 가희검수(5시) / 영숙캘린더(8시) / CEO스킬감사(월) / 루나영상(매일)")

    _clear_webhook()
    print(f"🤖 텔레그램 봇 시작 (chat_id={CHAT_ID})")
    send("🤖 AI 팀 봇 온라인 — /help 로 명령 목록을 확인하세요.")

    OFFSET_FILE = os.path.join(_here, "telegram_offset.txt")
    offset = 0
    if os.path.exists(OFFSET_FILE):
        try:
            with open(OFFSET_FILE, "r") as f:
                offset = int(f.read().strip())
        except:
            pass

    processed_messages = set()  # 중복 메시지 방지 (message_id 추적)

    while True:
        updates = get_updates(offset, timeout=0 if once else 30)

        for upd in updates:
            offset = upd["update_id"] + 1
            try:
                with open(OFFSET_FILE, "w") as f:
                    f.write(str(offset))
            except:
                pass
            msg = upd.get("message", {})
            msg_id = msg.get("message_id")
            text = msg.get("text", "").strip()
            cid  = str(msg.get("chat", {}).get("id", ""))

            if not text or cid != CHAT_ID:
                continue

            # 중복 메시지 체크
            if msg_id in processed_messages:
                print(f"  [중복 무시] message_id={msg_id}")
                continue

            processed_messages.add(msg_id)
            # 메모리 관리: 최근 100개만 유지
            if len(processed_messages) > 100:
                processed_messages.pop()

            print(f"  ← [{cid}] {text[:60]}")
            reply = route(text)
            send(reply, chat_id=cid)
            print(f"  → {reply[:80]}")

        if once:
            break
        time.sleep(1)


if __name__ == "__main__":
    main()
