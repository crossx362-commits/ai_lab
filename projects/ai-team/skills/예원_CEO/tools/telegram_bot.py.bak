# ─── Gemini & Google Calendar 연동 ──────────────────────────────────────────

CALENDAR_TOKEN_FILE = os.path.join(PROJECT_ROOT, ".agent", "credentials", "calendar_token.pickle")
PROMPT_FILE = os.path.join(PROJECT_ROOT, "assets", "prompts", "secretary-telegram.md")
CHAT_HISTORY = []  # 최근 대화 문맥 메모리 (최대 10개 유지)

def _get_calendar_service():
    """구글 캘린더 API 서비스 객체 획득 및 토큰 자동 갱신."""
    if not os.path.exists(CALENDAR_TOKEN_FILE):
        return None
    try:
        from google.auth.transport.requests import Request
        from googleapiclient.discovery import build
        with open(CALENDAR_TOKEN_FILE, "rb") as f:
            creds = pickle.load(f)
        if creds and creds.expired and creds.refresh_token:
            creds.refresh(Request())
            with open(CALENDAR_TOKEN_FILE, "wb") as f:
                pickle.dump(creds, f)
        return build("calendar", "v3", credentials=creds)
    except Exception as e:
        print(f"  [Warning] Calendar API 빌드 실패: {e}")
        return None


def call_gemini(user_message: str, force_gemini: bool = False) -> dict:
    """secretary-telegram.md 프롬프트 기반으로 비서 응답 생성. Ollama 1순위 → Gemini 폴백."""
    # 프롬프트 로드
    system_instruction = "You are a professional assistant."
    if os.path.exists(PROMPT_FILE):
        try:
            with open(PROMPT_FILE, "r", encoding="utf-8") as f:
                system_instruction = f.read()
        except Exception as e:
            print(f"  [Warning] 프롬프트 파일 로드 실패: {e}")

    # 1순위: Ollama (로컬) - force_gemini=True일 때는 스킵
    if not force_gemini and lm_available():
        print("  [Ollama] 텔레그램 비서 응답 생성 중...")
        history_text = ""
        for h in CHAT_HISTORY:
            role_name = "User" if h["role"] == "user" else "Assistant"
            history_text += f"{role_name}: {h['text']}\n"
        history_text += f"User: {user_message}\n"
        try:
            raw_resp = lm_chat(history_text, system=system_instruction, json_mode=True, max_tokens=1500)
            if raw_resp:
                result = json.loads(raw_resp.strip())
                CHAT_HISTORY.append({"role": "user", "text": user_message})
                CHAT_HISTORY.append({"role": "model", "text": raw_resp})
                if len(CHAT_HISTORY) > 20:
                    CHAT_HISTORY.pop(0); CHAT_HISTORY.pop(0)
                return result
        except Exception as lm_err:
            print(f"  [Ollama] 파싱 실패: {lm_err} → Gemini 폴백")

    # 2순위: Gemini API 폴백
    api_key = os.getenv("GEMINI_API_KEY", "")
    if api_key:
        contents = []
        for h in CHAT_HISTORY:
            contents.append({
                "role": h["role"],
                "parts": [{"text": h["text"]}]
            })
        contents.append({
            "role": "user",
            "parts": [{"text": user_message}]
        })

        url = f"https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key={api_key}"
        payload = {
            "systemInstruction": {
                "parts": [{"text": system_instruction}]
            },
            "contents": contents,
            "generationConfig": {
                "responseMimeType": "application/json"
            }
        }

        try:
            data = json.dumps(payload).encode("utf-8")
            req = urllib.request.Request(url, data=data, headers={"Content-Type": "application/json"})
            with urllib.request.urlopen(req, timeout=10) as r:
                res = json.loads(r.read().decode())
            
            # 응답 텍스트 추출 및 JSON 파싱
            cand = (res.get("candidates") or [{}])[0]
            text_resp = cand.get("content", {}).get("parts", [{}])[0].get("text", "{}")
            result = json.loads(text_resp.strip())

            # 문맥 누적 (성공 시에만)
            CHAT_HISTORY.append({"role": "user", "text": user_message})
            CHAT_HISTORY.append({"role": "model", "text": text_resp})
            if len(CHAT_HISTORY) > 20:  # 10턴 (user+model 쌍) 유지
                CHAT_HISTORY.pop(0)
                CHAT_HISTORY.pop(0)

            return result
        except Exception as e:
            print(f"  [Gemini] 호출 실패 ({e})")

    return {"mode": "reply", "text": "❌ Ollama 및 Gemini 모두 응답 불가 상태입니다."}


# ─── 구글 캘린더 CRUD 실시간 핸들러 ──────────────────────────────────────────

def handle_calendar_create(event_data: dict) -> str:
    service = _get_calendar_service()
    if not service:
        return "❌ 구글 캘린더 API 인증 정보(token_calendar.pickle)가 없어 일정을 생성할 수 없습니다."
    try:
        title = event_data.get("title", "회의")
        start_str = event_data.get("start")
        if not start_str:
            return "❌ 일정 생성 실패: 시작 시간 정보가 없습니다."
        dur = int(event_data.get("duration_minutes", 60))

        # 타임존 보정 (기본 KST)
        start_dt = datetime.datetime.fromisoformat(start_str.replace("Z", ""))
        end_dt = start_dt + datetime.timedelta(minutes=dur)

        body = {
            "summary": title,
            "description": event_data.get("description", ""),
            "location": event_data.get("location", ""),
            "start": {
                "dateTime": start_dt.isoformat(),
                "timeZone": "Asia/Seoul",
            },
            "end": {
                "dateTime": end_dt.isoformat(),
                "timeZone": "Asia/Seoul",
            }
        }
        service.events().insert(calendarId="primary", body=body).execute()
        return f"📅 <b>일정 등록 완료</b>\n- 제목: {title}\n- 시간: {start_dt.strftime('%m/%d %a %H:%M')} ({dur}분간)"
    except Exception as e:
        return f"❌ 일정 등록 실패: {e}"


def handle_calendar_list(days_ahead: int) -> str:
    service = _get_calendar_service()
    if not service:
        return "❌ 구글 캘린더 API 인증 정보가 없어 일정을 조회할 수 없습니다."
    try:
        now = datetime.datetime.utcnow().isoformat() + "Z"
        time_max = (datetime.datetime.utcnow() + datetime.timedelta(days=days_ahead)).isoformat() + "Z"
        
        events_result = service.events().list(
            calendarId="primary", timeMin=now, timeMax=time_max,
            singleEvents=True, orderBy="startTime"
        ).execute()
        events = events_result.get("items", [])

        if not events:
            return f"📭 다가오는 {days_ahead}일 동안 일정이 없습니다."

        lines = [f"📅 <b>다가오는 일정 (향후 {days_ahead}일)</b>"]
        for ev in events:
            start_str = ev["start"].get("dateTime") or ev["start"].get("date")
            # 포맷 변환
            if "T" in start_str:
                dt = datetime.datetime.fromisoformat(start_str.split("+")[0])
                ts = dt.strftime("%m/%d %a %H:%M")
            else:
                dt = datetime.datetime.strptime(start_str, "%Y-%m-%d")
                ts = dt.strftime("%m/%d %a (종일)")
            
            lines.append(f"• {ts} — {ev.get('summary', '(제목 없음)')}")
        return "\n".join(lines)
    except Exception as e:
        return f"❌ 일정 조회 실패: {e}"


def handle_calendar_delete(query: str, days_ahead: int, delete_all: bool) -> str:
    service = _get_calendar_service()
    if not service:
        return "❌ 구글 캘린더 API 인증 정보가 없어 일정을 취소할 수 없습니다."
    try:
        now = datetime.datetime.utcnow().isoformat() + "Z"
        time_max = (datetime.datetime.utcnow() + datetime.timedelta(days=days_ahead)).isoformat() + "Z"
        events_result = service.events().list(
            calendarId="primary", timeMin=now, timeMax=time_max,
            singleEvents=True, orderBy="startTime"
        ).execute()
        events = events_result.get("items", [])

        matched = [ev for ev in events if query.lower() in ev.get("summary", "").lower()]
        if not matched:
            return f"❓ '{query}' 키워드가 들어간 일정을 찾지 못했습니다."

        to_delete = matched if delete_all else matched[:1]
        deleted_titles = []
        for ev in to_delete:
            service.events().delete(calendarId="primary", eventId=ev["id"]).execute()
            deleted_titles.append(ev.get("summary", "(제목 없음)"))

        titles_str = ", ".join([f"'{t}'" for t in deleted_titles])
        return f"🗑️ <b>일정 취소 완료</b>\n- 삭제 대상: {titles_str} ({len(deleted_titles)}건)"
    except Exception as e:
        return f"❌ 일정 취소 실패: {e}"


def handle_calendar_update(query: str, days_ahead: int, patch_data: dict) -> str:
    service = _get_calendar_service()
    if not service:
        return "❌ 구글 캘린더 API 인증 정보가 없어 일정을 수정할 수 없습니다."
    try:
        now = datetime.datetime.utcnow().isoformat() + "Z"
        time_max = (datetime.datetime.utcnow() + datetime.timedelta(days=days_ahead)).isoformat() + "Z"
        events_result = service.events().list(
            calendarId="primary", timeMin=now, timeMax=time_max,
            singleEvents=True, orderBy="startTime"
        ).execute()
        events = events_result.get("items", [])

        matched = [ev for ev in events if query.lower() in ev.get("summary", "").lower()]
        if not matched:
            return f"❓ '{query}' 키워드가 들어간 일정을 찾지 못했습니다."

        target_event = matched[0]  # 가장 가까운 1개 수정
        body = {}
        
        if "title" in patch_data:
            body["summary"] = patch_data["title"]
            
        if "start" in patch_data:
            new_start_str = patch_data["start"]
            new_start = datetime.datetime.fromisoformat(new_start_str.replace("Z", ""))
            
            # 기존 기간(duration) 계산 또는 기본값 60분
            existing_start_str = (target_event["start"].get("dateTime") or "").split("+")[0]
            existing_end_str   = (target_event["end"].get("dateTime") or "").split("+")[0]
            if not existing_start_str or not existing_end_str:
                return "❌ 일정 수정 실패: 기존 일정 시간 정보를 읽을 수 없습니다."
            existing_start = datetime.datetime.fromisoformat(existing_start_str)
            existing_end   = datetime.datetime.fromisoformat(existing_end_str)
            dur = patch_data.get("duration_minutes")
            if dur is not None:
                dur = int(dur)
            else:
                dur = int((existing_end - existing_start).total_seconds() / 60)
            
            new_end = new_start + datetime.timedelta(minutes=dur)
            body["start"] = {"dateTime": new_start.isoformat(), "timeZone": "Asia/Seoul"}
            body["end"] = {"dateTime": new_end.isoformat(), "timeZone": "Asia/Seoul"}
        elif "duration_minutes" in patch_data:
            existing_start = datetime.datetime.fromisoformat(target_event["start"].get("dateTime").split("+")[0])
            dur = int(patch_data["duration_minutes"])
            new_end = existing_start + datetime.timedelta(minutes=dur)
            body["end"] = {"dateTime": new_end.isoformat(), "timeZone": "Asia/Seoul"}

        res = service.events().patch(calendarId="primary", eventId=target_event["id"], body=body).execute()
        return f"📝 <b>일정 수정 완료</b>\n- 기존 일정: '{target_event.get('summary')}'\n- 변경 완료: '{res.get('summary')}'"
    except Exception as e:
        return f"❌ 일정 수정 실패: {e}"

